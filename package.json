{
    "name": "elhuff-check-in",
    "version": "1.0.0",
    "private": true,
    "description": "Checks the presented ID to see if it is a valid ID and records the entry/exit of the user",
    "type": "module",
    "main": "bin/index.js",
    "keywords": [
        "automation",
        "check-in",
        "membership",
        "management",
        "kiosk"
    ],
    "homepage": "https://github.com/elliot-huffman/check-in#readme",
    "bugs": {
        "url": "https://github.com/elliot-huffman/check-in/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/elliot-huffman/check-in.git"
    },
    "license": "MIT",
    "author": "Elliot Huffman",
    "scripts": {
        "prepare": "ts-patch install",
        "prebuild:Prod": "next telemetry disable",
        "prebuild:Dev": "next telemetry disable",
        "start:Runtime": "electron .",
        "start:UserInterface": "next dev user-interface --hostname localhost --port 3000",
        "build:Prod": "npm run build:Prod:Runtime && npm run build:Prod:UserInterface",
        "build:Prod:Runtime": "tsc --project runtime --sourceMap false",
        "build:Prod:UserInterface": "next build user-interface",
        "build:Dev": "npm run build:Dev:Runtime && npm run build:Dev:UserInterface",
        "build:Dev:Runtime": "tsc --project runtime",
        "build:Dev:UserInterface": "npm run build:Prod:UserInterface",
        "lint": "npm run lint:Runtime && npm run lint:UserInterface",
        "lint:Runtime": "eslint ./runtime/",
        "lint:UserInterface": "eslint ./user-interface/",
        "test": "npm run test:Unit && npm run test:Integration",
        "test:Unit": "echo Coming soon!",
        "test:Integration": "echo Coming soon!",
        "package": "electron-builder build --config electronBuilder.ts",
        "generate:LicenseList": "generate-license-file --input package.json --output ./user-interface/public/LicenseList.txt --overwrite"
    },
    "packageManager": "npm@11.12.1",
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": ">=24.13.0",
            "onFail": "error"
        },
        "packageManager": {
            "name": "npm",
            "onFail": "error"
        }
    },
    "devDependencies": {
        "@electron/fuses": "~2.1.1",
        "@shi-corp/development-utilities": "~2.2.0",
        "@types/jws": "~3.2.11",
        "babel-plugin-react-compiler": "~1.0.0",
        "electron": "~41.2.0",
        "electron-builder": "~26.8.1",
        "generate-license-file": "~4.1.1",
        "ts-patch": "~3.3.0",
        "typescript": "~5.9.3"
    },
    "dependencies": {
        "@azure/identity": "~4.13.1",
        "@fluentui/react-components": "~9.73.7",
        "@fluentui/react-icons": "~2.0.323",
        "@reduxjs/toolkit": "~2.11.2",
        "jws": "~4.0.1",
        "next": "~16.2.3",
        "react": "~19.2.5",
        "react-dom": "~19.2.5",
        "react-redux": "~9.2.0",
        "typia": "~12.0.2"
    }
}
